# Garmin auth tokens (expiring OAuth session — never commit)
.garmin_tokens/

# Fetched data & local FIT files
garmin_out/
*.fit
*.FIT

# Python
__pycache__/
*.pyc
.venv/
venv/
.env

# Generated DB / logs
golf.db
*.log

# Frontend build artifacts
web/node_modules/
web/.next/
web/out/
web/_preview/
web/.env.local

# NOTE: web/public/data/*.json (exported by export_static.py) IS committed —
# it's the data the static GitHub Pages build serves.
